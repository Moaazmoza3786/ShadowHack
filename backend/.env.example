# ============================================================
#  ShadowHack Backend — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────

# Flask secret key — used for session signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# JWT signing secret — used to sign authentication tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-another-long-random-string


# ── DATABASE ─────────────────────────────────────────────────

# PostgreSQL connection URL for production.
# If unset, SQLite is used automatically for development.
# Example: postgresql://user:password@host:5432/shadowhack
DATABASE_URL=


# ── PLATFORM ACCESS GATE ─────────────────────────────────────

# Invite-only access code shown at the PasswordGate screen.
# Validated server-side via POST /api/auth/verify-access.
# Leave blank to make the platform open to everyone.
PLATFORM_ACCESS_CODE=


# ── FLASK SETTINGS ───────────────────────────────────────────

# Set to "development" to enable debug mode and relaxed CORS (allows all origins).
# Leave blank or set to "production" for production behaviour.
FLASK_ENV=development

# Set to "true" to log all SQL queries (useful for debugging).
SQL_DEBUG=false

# Port the Flask server listens on (default: 5000).
PORT=5000

# ── CORS ─────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# Only used when FLASK_ENV != "development".
# Example: https://shadowhack.vercel.app,https://www.shadowhack.io
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ── RATE LIMITING ─────────────────────────────────────────────

# Redis URI for distributed rate limiting.
# Strongly recommended in production (multiple workers share state).
# Falls back to in-memory storage if unset (resets on restart).
# Example: redis://localhost:6379/0
RATELIMIT_STORAGE_URI=


# ── AI INTEGRATION (Groq) ────────────────────────────────────

# Groq API key — powers the AI assistant, news generator, and code analyser.
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# Optional: OpenAI API key (not used by default, reserved for future use).
OPENAI_API_KEY=

# Optional: Shodan API key for the OSINT recon tool.
SHODAN_API_KEY=

# Optional: Ollama local LLM endpoint (if using a local model instead of Groq).
OLLAMA_URL=http://localhost:11434

# Which AI provider to use: groq | openai | local
AI_PROVIDER=groq


# ── EMAIL / SMTP ─────────────────────────────────────────────

# SMTP settings for sending password-reset emails.
# Gmail example — you must create an App Password (not your account password).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=ShadowHack

# Base URL used to build password-reset links in emails.
FRONTEND_URL=http://localhost:3000


# ── SSL (LOCAL DEVELOPMENT ONLY) ─────────────────────────────

# Path to TLS certificate and key for HTTPS in local development.
# Generate with: mkcert localhost
# If the files are not found, the server falls back to plain HTTP.
# SSL_CERT_PATH=../localhost.pem
# SSL_KEY_PATH=../localhost-key.pem
