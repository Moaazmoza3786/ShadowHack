# ============================================================
#  ShadowHack React Frontend — Environment Variables Template
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ============================================================

# ── API Backend ──────────────────────────────────────────────
# URL of the Flask backend API.
# In development the Vite proxy rewrites /api → http://127.0.0.1:5000,
# so you can leave this blank (defaults to /api).
# In production point it at your deployed backend URL.
VITE_API_URL=

# ── Supabase (optional) ──────────────────────────────────────
# Only required if you want to use Supabase for auth or storage.
# Leave blank to run without Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Feature Flags ────────────────────────────────────────────
# Set to "true" to enable experimental features in development.
VITE_ENABLE_DEBUG_TOOLS=false
